{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "currency": { "type": "string", "enum": ["INR", "USD", "EUR", "GBP"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "An income or expense entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "accountId": { "type": "string" },
        "receiptUrl": { "type": "string" },
        "isRecurring": { "type": "boolean" },
        "recurringInterval": { "type": "string", "enum": ["daily", "weekly", "monthly", "yearly"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "amount", "category", "date", "type", "accountId"]
    },
    "Account": {
      "title": "Account",
      "description": "A financial account (Cash, Bank, UPI)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["cash", "bank", "upi"] },
        "balance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "type", "balance"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly budget for a category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "month": { "type": "integer" },
        "year": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "category", "amount", "month", "year"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Financial savings goal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "targetAmount", "currentAmount"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Income and expense transactions"
    },
    "/accounts/{accountId}": {
      "schema": "Account",
      "description": "Financial accounts"
    },
    "/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Monthly budgets"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Savings goals"
    }
  }
}
